# Frontend API URL used by Axios in all environments
# For Vercel backend, set this to your deployed backend origin + /api
# Example: VITE_API_BASE_URL=https://software-business-assignment-vibe-c.vercel.app/api
VITE_API_BASE_URL=https://software-business-assignment-vibe-c.vercel.app/api

# Dev-only proxy target used by Vite when your Axios base URL is /api
# Example (local backend): VITE_DEV_API_PROXY_TARGET=http://localhost:3000
VITE_DEV_API_PROXY_TARGET=http://localhost:3000
